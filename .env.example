# Server
PORT=3000
NODE_ENV=development

# Storage/infra
DATABASE_URL=postgres://postgres:postgres@localhost:5432/claw
REDIS_URL=redis://localhost:6379

# Access token
JWT_SECRET=replace-with-strong-jwt-secret
JWT_TTL_SEC=21600

# Telegram auth
TELEGRAM_BOT_TOKEN=000000000:REPLACE_WITH_BOT_TOKEN
TELEGRAM_INIT_DATA_TTL_SEC=120

# Dev auth
DEV_AUTH_ENABLED=true
DEV_AUTH_USER_PREFIX=dev

# No-auth mode (local testing only)
AUTH_DISABLED=false
AUTH_DISABLED_USER_ID=noauth-user
AUTH_DISABLED_TELEGRAM_USER_ID=dev:noauth-user
AUTH_DISABLED_SKIP_TICKET_DEBIT=true

# Attempt token
ATTEMPT_TOKEN_SECRET=replace-with-strong-attempt-secret
ATTEMPT_TTL_SEC=300
INPUT_RATE_LIMIT_PER_SEC=30
GAME_SETTINGS_PATH=config/game-settings.json

# Audit/economy
AUDIT_LOG_ENABLED=true
DEFAULT_TICKETS=5

# Outbound webhook about resolve result (win/lose/void)
ATTEMPT_RESULT_WEBHOOK_ENABLED=true
ATTEMPT_RESULT_WEBHOOK_URL=http://127.0.0.1:3000/v1/debug/attempt-result
ATTEMPT_RESULT_WEBHOOK_TIMEOUT_MS=1500
ATTEMPT_RESULT_WEBHOOK_AUTH_TOKEN=
ATTEMPT_RESULT_WEBHOOK_INCLUDE_SEED=false
